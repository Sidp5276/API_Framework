<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite">
    <test verbose="2" name="Smoke">
        <groups>
            <run>
                <!-- This forces TestNG to ONLY execute the smoke group -->
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <!-- Points directly to your specific package and class -->
            <class name="com.ApiFramework.ex_04_TestNGAdvanceExample.APITesting015_TestNG_Groups"/>
        </classes>
    </test>
</suite>